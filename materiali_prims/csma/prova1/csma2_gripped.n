nondeterministic


module bus

  b : [ 0 .. 2 ] ; 
  ya : [ 0 .. 2 ] ; 
  yb : [ 0 .. 2 ] ; 

  [send] (b=0) -> (b'=1);
  [send] (b=1|b=2)&(ya<1) -> (b'=2);
  [end] (b=1) -> (b'=0)&(ya'=0);
  [busy] (b=1|b=2)&(ya>=1) -> (b'=b);
  [cd] (b=2)&(yb<=1) -> (b'=0)&(ya'=0)&(yb'=0);
  [time] (b=0) -> (ya'=0);
  [time] (b=1) -> (ya'=min(ya+1,2));
  [time] (b=2)&(yb<1) -> (ya'=min(ya+1,2))&(yb'=min(yb+1,2));
endmodule

